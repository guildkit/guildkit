{
  "extends": "@phanect/configs/ts/nodejs",

  // Check by ESLint to ignore files under tmp/
  "compilerOptions": {
    "incremental": true
  },

  "tsBuildInfoFile": "./.tsbuildinfo",
  "references": [
    {
      "path": "projects/backend"
    },
    {
      "path": "projects/client"
    },
    {
      "path": "projects/db"
    },
    {
      "path": "projects/frontend"
    },
    {
      "path": "projects/shared"
    },
    {
      "path": "demo"
    }
  ],

  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx"
  ],
  "exclude": [
    "**/node_modules/**",
    // These files should be lint by each project's mise tasks
    "projects/*/**",
    "demo/**"
  ]
}
