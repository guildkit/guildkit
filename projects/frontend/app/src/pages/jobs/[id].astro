---
import { getJob } from "@guildkit/client";
import PublicLayout from "@/layouts/PublicLayout.astro";

const { id } = Astro.params;
const job = id ? await getJob(id, undefined) : undefined;

if (!job) {
  return Astro.rewrite("/404");
}
---

<PublicLayout>
  <div class="w-full max-w-4xl px-9">
    <h1 class="text-3xl font-black text-gray-900 mb-2">{ job.title }</h1>
    <a
      href={`/orgs/${ job.employer.slug }`}
      class="linktext inline-flex items-center gap-2 mb-3 text-lg text-gray-900 font-bold"
    >
      <img src="/vendor/octicons/organization.svg" alt="Employer" width={18} height={18} />
      { job.employer.name }
    </a>
    <div class="mb-6">
      <span class="inline-flex items-center gap-1.5 mr-2 py-2 px-4 text-sm font-medium text-gray-800 bg-gray-200 rounded-full">
        <img src="/vendor/octicons/location.svg" alt="" width={16} height={16} />
        Work location: { job.location }
      </span>
      <span class="inline-flex items-center gap-1.5 mr-2 py-2 px-4 text-sm font-medium text-gray-800 bg-green-200 rounded-full">
        <img src="/vendor/tabler/coins.svg" alt="" width={16} height={16} />
        {/* TODO Use user's locale in `toLocaleString()` */}
        Salary: { job.salary.toLocaleString("en-US") } { job.currency }/{ job.salaryPer }
      </span>
    </div>
    <div class="inline-flex items-center gap-1.5 justify-end w-full mb-6 text-sm">
      <img src="/vendor/octicons/clock.svg" alt="" width={16} height={16} />
      {/* TODO Use user's locale in `toLocaleString()` */}
      Last updated at { (job.updatedAt ?? job.createdAt).toLocaleDateString("en-US") }
    </div>

    <section class="mb-5">
      <h3 class="text-2xl font-bold text-gray-800 mb-2">Description</h3>
      <p>{ job.description }</p>
    </section>

    <section class="mt-8">
      <a
        href={ job.applicationUrl }
        class="button-deep px-6 py-3 font-semibold rounded-lg"
      >
        Apply
      </a>
    </section>
  </div>
</PublicLayout>
