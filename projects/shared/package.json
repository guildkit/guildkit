{
  "name": "@guildkit/shared",
  "version": "0.0.1-prealpha",
  "description": "GuildKit's internal shared library for backend & frontend",
  "author": {
    "name": "tenkumo, Inc.",
    "url": "https://tenkumo.com"
  },
  "contributors": [
    {
      "name": "Jumpei Ogawa",
      "url": "https://phanective.org"
    }
  ],
  "license": "Apache-2.0",
  "type": "module",
  "module": "./dist/index.mjs",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./auth": {
      "types": "./dist/auth.d.mts",
      "default": "./dist/auth.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "default": "./dist/cli.mjs"
    },
    "./prisma": {
      "types": "./dist/prisma.d.mts",
      "default": "./dist/prisma.mjs"
    },
    "./zod": {
      "types": "./dist/zod.d.mts",
      "default": "./dist/zod.mjs"
    }
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "better-auth": "1.6.11",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@phanect/configs": "2026.5.19",
    "@phanect/utils": "^3.0.0",
    "@types/pg": "^8.15.6",
    "auth": "1.6.11",
    "dayjs": "^1.11.20",
    "fast-xml-parser": "^5.3.1",
    "prisma": "^7.6.0",
    "tsdown": "0.22.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": "24.x"
  }
}
