# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Server environment: development | production | demo-production | demo-preview
SERVER_ENV="development"

# PostgreSQL (local Docker/Podman container)
DATABASE_URL="postgresql://guildkit:guildkit@localhost:5432/guildkit"

# Application base URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# better-auth secret — change this in production!
BETTER_AUTH_SECRET="change-me-to-a-long-random-string-in-production"

# S3-compatible object storage (local RustFS container)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="guildkit"
S3_SECRET_ACCESS_KEY="guildkit"
S3_BUCKET="guildkit"
