generator nodejs {
  provider      = "prisma-client"
  compilerBuild = "fast"
  output        = "../src/lib/prisma/nodejs"
  runtime       = "nodejs"
}

generator cloudflare {
  provider      = "prisma-client"
  compilerBuild = "fast"
  output        = "../src/lib/prisma/cloudflare"
  runtime       = "cloudflare"
}

datasource db {
  provider = "postgresql"
}
