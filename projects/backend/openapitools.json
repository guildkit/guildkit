{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.23.0",
    "generators": {
      "client": {
        "inputSpec": "./intermediate/openapi.json",
        "generatorName": "typescript-fetch",
        "output": "#{cwd}/../client",
        "additionalProperties": {
          "npmName": "@guildkit/client",
          "supportsES6": "true",
          "withInterfaces": true
        }
      }
    }
  }
}
